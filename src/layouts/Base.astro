---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <ClientRouter />
    <title>{title}</title>
    <script is:inline>
      // Apply theme immediately before page renders to prevent flash
      // This must run synchronously before any rendering
      (function() {
        try {
          const saved = localStorage.getItem('theme');
          const html = document.documentElement;
          if (saved === 'dark') {
            html.classList.add('dark');
          } else {
            html.classList.remove('dark');
          }
        } catch (e) {
          // If localStorage fails, default to light mode
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    <style>
      html {
        scroll-behavior: smooth;
      }
      
      * {
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Page transition styles */
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.3s;
        animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }

      ::view-transition-old(root) {
        animation-name: fade-out;
      }

      ::view-transition-new(root) {
        animation-name: fade-in;
      }

      @keyframes fade-out {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
        }
      }

      @keyframes fade-in {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      /* Fallback for browsers without view transitions */
      @supports not (view-transition-name: none) {
        body {
          transition: opacity 0.3s ease-in-out;
        }
      }

      /* Animated Background Pattern */
      .subtle-bg {
        background-color: #FAFAFA;
        position: relative;
      }

      .subtle-bg::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 100vh;
        background-image: 
          linear-gradient(rgba(101, 67, 33, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(101, 67, 33, 0.04) 1px, transparent 1px);
        background-size: 50px 50px;
        animation: gridMove 20s linear infinite;
        pointer-events: none;
        z-index: 0;
      }

      .subtle-bg::after {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 100vh;
        background: radial-gradient(circle, rgba(101, 67, 33, 0.04) 1px, transparent 1px);
        background-size: 80px 80px;
        animation: dotMove 30s linear infinite;
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
      }

      nav, footer {
        position: relative;
        z-index: 1;
        background-color: #FAFAFA;
      }

      /* Dark mode background adjustments */
      .dark .subtle-bg {
        background-color: #1A1A1A;
      }

      .dark .subtle-bg::before {
        background-image: 
          linear-gradient(rgba(166, 124, 82, 0.08) 1px, transparent 1px),
          linear-gradient(90deg, rgba(166, 124, 82, 0.08) 1px, transparent 1px);
      }

      .dark .subtle-bg::after {
        background: radial-gradient(circle, rgba(166, 124, 82, 0.1) 1px, transparent 1px);
      }

      .dark nav,
      .dark footer {
        background-color: #1A1A1A;
      }

      @keyframes gridMove {
        0% {
          transform: translate(0, 0);
        }
        100% {
          transform: translate(50px, 50px);
        }
      }

      @keyframes dotMove {
        0% {
          transform: translate(0, 0) rotate(0deg);
        }
        100% {
          transform: translate(40px, 40px) rotate(360deg);
        }
      }

      /* Personal Logo Mark */
      .logo-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #654321, #A67C52);
        color: white;
        font-size: 0.875rem;
        font-weight: 700;
        border-radius: 6px;
        letter-spacing: -0.5px;
      }
    </style>
  </head>
  <body class="bg-[#FAFAFA] dark:bg-[#1A1A1A] font-sans antialiased scroll-smooth subtle-bg">
    <nav class="flex justify-between items-center px-4 sm:px-6 py-4 sm:py-5 w-full relative border-b border-gray-200 dark:border-gray-700 bg-[#FAFAFA] dark:bg-[#1A1A1A]">
      <a href="/" class="text-xl sm:text-2xl font-bold text-[#654321] dark:text-[#A67C52] hover:opacity-70 transition-all duration-300 ease-in-out flex items-center gap-2">
        <span class="logo-mark">PD</span>
        <span>Parth Dhingra</span>
      </a>
      <div class="hidden md:flex gap-10 absolute left-1/2 transform -translate-x-1/2">
        {!isHomePage && (
          <a href="/" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Home</a>
        )}
        <a href="/projects" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Projects</a>
        <a href="/contact" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Contact</a>
      </div>
      <div class="flex items-center gap-4">
        <div class="md:hidden flex gap-4 sm:gap-6 text-sm sm:text-base">
          {!isHomePage && (
            <a href="/" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Home</a>
          )}
          <a href="/projects" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Projects</a>
          <a href="/contact" class="text-[#1A1A1A] dark:text-gray-200 hover:opacity-70 transition-all duration-300 ease-in-out">Contact</a>
        </div>
        <!-- Dark Mode Toggle -->
        <button
          id="dark-mode-toggle"
          class="relative inline-flex h-8 w-16 items-center rounded-full bg-gray-300 dark:bg-gray-600 transition-colors focus:outline-none focus:ring-2 focus:ring-[#654321] dark:focus:ring-[#A67C52] focus:ring-offset-2 overflow-hidden"
          aria-label="Toggle dark mode"
          type="button"
        >
          <!-- Sun Icon (Light Mode) - visible in light mode -->
          <span class="absolute left-2 h-4 w-4 text-yellow-500 transition-all duration-300 opacity-100 scale-100 dark:opacity-0 dark:scale-0 dark:pointer-events-none">
            <svg fill="currentColor" viewBox="0 0 20 20" class="w-full h-full">
              <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
            </svg>
          </span>
          <!-- Moon Icon (Dark Mode) - visible in dark mode -->
          <span class="absolute right-2 h-4 w-4 text-gray-200 transition-all duration-300 opacity-0 scale-0 dark:opacity-100 dark:scale-100 pointer-events-none">
            <svg fill="currentColor" viewBox="0 0 20 20" class="w-full h-full">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
            </svg>
          </span>
          <!-- Toggle Slider -->
          <span
            id="dark-mode-toggle-slider"
            class="absolute h-6 w-6 transform rounded-full bg-white dark:bg-gray-800 shadow-lg transition-all duration-300 left-1 dark:left-[calc(100%-1.5rem)] flex items-center justify-center z-10"
          >
            <!-- Small icon inside slider -->
            <span class="h-3 w-3 text-yellow-500 dark:text-gray-200 transition-all duration-300 opacity-100 dark:opacity-0">
              <svg fill="currentColor" viewBox="0 0 20 20" class="w-full h-full">
                <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
              </svg>
            </span>
            <span class="absolute h-3 w-3 text-gray-200 dark:text-gray-300 transition-all duration-300 opacity-0 dark:opacity-100">
              <svg fill="currentColor" viewBox="0 0 20 20" class="w-full h-full">
                <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
              </svg>
            </span>
          </span>
        </button>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="w-full px-6 py-8 text-center border-t border-gray-200 dark:border-gray-700 mt-12 bg-[#FAFAFA] dark:bg-[#1A1A1A]">
      <p class="text-sm text-gray-500 dark:text-gray-300">
        © {currentYear} Parth Dhingra. All rights reserved.
      </p>
    </footer>

    <script is:inline>
      (function() {
        // Apply theme function - make it global so it can be called from anywhere
        window.applyTheme = function(theme) {
          try {
            const html = document.documentElement;
            if (theme === 'dark') {
              html.classList.add('dark');
              localStorage.setItem('theme', 'dark');
            } else {
              html.classList.remove('dark');
              localStorage.setItem('theme', 'light');
            }
            return true;
          } catch (e) {
            console.error('Error applying theme:', e);
            return false;
          }
        };

        // Initialize dark mode toggle
        const initDarkMode = () => {
          const toggle = document.getElementById('dark-mode-toggle');
          
          if (toggle) {
            // Remove all existing event listeners by replacing the button
            const newToggle = toggle.cloneNode(true);
            toggle.parentNode.replaceChild(newToggle, toggle);
            
            // Add click listener to new toggle with proper event handling
            newToggle.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              
              const html = document.documentElement;
              const isDark = html.classList.contains('dark');
              const newTheme = isDark ? 'light' : 'dark';
              
              window.applyTheme(newTheme);
              
              // Prevent any default behavior
              return false;
            }, true); // Use capture phase to ensure it fires
          }
        };

        // Initialize on page load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initDarkMode);
        } else {
          initDarkMode();
        }

        // Listen for Astro view transitions to re-apply theme and re-init toggle
        document.addEventListener('astro:page-load', () => {
          try {
            const saved = localStorage.getItem('theme') || 'light';
            window.applyTheme(saved);
            // Re-initialize toggle after page load with a small delay
            setTimeout(initDarkMode, 50);
          } catch (e) {
            console.error('Error in page-load handler:', e);
          }
        });

        // Also listen for beforeunload to ensure theme persists
        window.addEventListener('beforeunload', () => {
          const theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
          try {
            localStorage.setItem('theme', theme);
          } catch (e) {
            // Ignore errors
          }
        });
      })();
    </script>

    <!-- Image Lightbox Modal -->
    <div id="image-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-90 dark:bg-opacity-95" style="display: none;">
      <div class="relative max-w-7xl max-h-[90vh] w-full h-full flex items-center justify-center p-4">
        <button 
          id="lightbox-close" 
          class="absolute top-4 right-4 text-white hover:text-gray-300 text-4xl font-bold z-10 bg-black bg-opacity-50 rounded-full w-12 h-12 flex items-center justify-center transition-all hover:bg-opacity-70"
          aria-label="Close lightbox"
        >
          ×
        </button>
        <img 
          id="lightbox-image" 
          src="" 
          alt="" 
          class="max-w-full max-h-full object-contain rounded-lg"
        />
      </div>
    </div>

    <style>
      #image-lightbox {
        backdrop-filter: blur(4px);
      }
      
      #image-lightbox.show {
        display: flex !important;
      }
      
      .image-lightbox {
        cursor: zoom-in;
      }
    </style>

    <script>
      (function() {
        // Initialize lightbox functionality
        const initLightbox = () => {
          const lightbox = document.getElementById('image-lightbox');
          const lightboxImage = document.getElementById('lightbox-image');
          const lightboxClose = document.getElementById('lightbox-close');
          const images = document.querySelectorAll('.image-lightbox');

          if (!lightbox || !lightboxImage || !lightboxClose) return;

          // Open lightbox
          const openLightbox = (src, alt) => {
            lightboxImage.src = src;
            lightboxImage.alt = alt || '';
            lightbox.classList.add('show');
            document.body.style.overflow = 'hidden';
          };

          // Close lightbox
          const closeLightbox = () => {
            lightbox.classList.remove('show');
            document.body.style.overflow = '';
          };

          // Add click handlers to all images
          images.forEach(img => {
            img.addEventListener('click', (e) => {
              e.preventDefault();
              const src = img.getAttribute('data-lightbox-src') || img.src;
              const alt = img.getAttribute('data-lightbox-alt') || img.alt || '';
              openLightbox(src, alt);
            });
          });

          // Close on button click
          lightboxClose.addEventListener('click', closeLightbox);

          // Close on background click
          lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) {
              closeLightbox();
            }
          });

          // Close on Escape key
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && lightbox.classList.contains('show')) {
              closeLightbox();
            }
          });
        };

        // Initialize on page load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLightbox);
        } else {
          initLightbox();
        }

        // Re-initialize on Astro page transitions
        document.addEventListener('astro:page-load', () => {
          setTimeout(initLightbox, 50);
        });
      })();
    </script>
  </body>
</html>
