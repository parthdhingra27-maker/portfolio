---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => {
    // Sort by custom order field if available, otherwise by publishedDate or year
    if (a.data.order !== undefined && b.data.order !== undefined) {
      return a.data.order - b.data.order;
    }
    if (a.data.order !== undefined) return -1; // Items with order come first
    if (b.data.order !== undefined) return 1;
    // Default: sort by publishedDate (most recent first), then by year
    if (a.data.publishedDate && b.data.publishedDate) {
      return new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime();
    }
    if (a.data.publishedDate) return -1; // Items with publishedDate come first
    if (b.data.publishedDate) return 1;
    return b.data.year - a.data.year;
  }
);

// Show only top 3 projects on homepage based on order
const projects = allProjects.slice(0, 3);
---

<Base title="Parth Dhingra">
  <!-- Hero Section -->
  <section class="w-full px-4 sm:px-6 py-12 sm:py-20 grid grid-cols-1 md:grid-cols-2 items-center gap-8 md:gap-12">
    <div class="flex flex-col items-center md:items-start hero-content text-center md:text-left">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-3 text-[#1A1A1A] dark:text-gray-100 hero-title">
        Hi, I'm Parth Dhingra
      </h1>
      <p class="text-xl sm:text-2xl font-normal text-[#4B5563] dark:text-gray-100 mb-6 hero-subtitle">
        Mechanical Engineering Student @ George Mason University
      </p>
      <p class="text-lg leading-relaxed text-[#4B5563] dark:text-gray-100 mb-8 hero-bio">
        Welcome to my portfolio! I build useful robotic and electrical projects.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto justify-center md:justify-start">
        <a href="/projects" class="bg-[#654321] text-white px-5 py-2.5 rounded-xl flex items-center justify-center gap-2 hover:opacity-90 transition-all duration-300 ease-in-out transform hover:scale-105 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          View My Work
        </a>
        <a href="#resume" class="border border-[#E5E7EB] dark:border-gray-600 bg-white dark:bg-gray-800 px-5 py-2.5 rounded-xl flex items-center justify-center gap-2 hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300 ease-in-out transform hover:scale-105 text-[#1A1A1A] dark:text-gray-200 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          View Resume
        </a>
        <a href="https://www.linkedin.com/in/parthd27/" target="_blank" rel="noopener noreferrer" class="border border-[#E5E7EB] dark:border-gray-600 bg-white dark:bg-gray-800 px-5 py-2.5 rounded-xl flex items-center justify-center gap-2 hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300 ease-in-out transform hover:scale-105 text-[#1A1A1A] dark:text-gray-200 text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
    <div class="flex justify-center items-center hero-image">
      <img 
        src="/hero-image.png" 
        alt="Parth Dhingra" 
        class="w-full max-w-md rounded-2xl shadow-lg object-cover"
      />
    </div>
  </section>

  <!-- About Me Section -->
  <section class="w-full px-4 sm:px-6 py-8 sm:py-12 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-6 text-[#1A1A1A] dark:text-gray-100">About Me</h2>
    <p class="text-lg leading-relaxed text-[#4B5563] dark:text-gray-100 mb-4">
      I'm a freshman studying Mechanical Engineering at George Mason University. My interests include robotics, CAD design, 3D printing, and metal and woodworking. I enjoy taking on projects that combine creativity with engineering problem-solving. From leading the mechanical subteam in my high school robotics club to running a small 3D printing business, I’ve gained hands-on experience in design, fabrication, and prototyping. I’m excited to continue developing these skills and applying them to new challenges.
    </p>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="w-full px-4 sm:px-6 py-8 sm:py-12">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4 sm:mb-6 text-[#1A1A1A] dark:text-gray-100 text-center">Latest Projects</h2>
    <p class="text-center text-[#4B5563] dark:text-gray-100 mb-4 text-sm sm:text-base">
      Here are some of the projects I've been working on. Click on any of them to learn more!
    </p>
    <div class="text-center mb-6 sm:mb-8">
      <a 
        href="/projects" 
        class="inline-flex items-center justify-center gap-2 border border-[#E5E7EB] dark:border-gray-600 bg-white dark:bg-gray-800 px-6 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300 ease-in-out transform hover:scale-105 text-[#1A1A1A] dark:text-gray-200 font-medium shadow-sm hover:shadow-md"
      >
        View All Projects
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 max-w-7xl mx-auto">
      {projects.map((project) => {
        const publishedDate = project.data.publishedDate 
          ? new Date(project.data.publishedDate).toLocaleDateString('en-US', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })
          : null;
        
        return (
          <a 
            href={`/projects/${project.slug}`}
            class="block bg-white dark:bg-gray-800 rounded-xl border border-[#F3F4F6] dark:border-gray-700 overflow-hidden shadow-sm hover:shadow-xl hover:border-[#654321]/30 dark:hover:border-[#A67C52]/50 transition-all duration-300 ease-in-out transform hover:scale-[1.02] hover:-translate-y-1 cursor-pointer group project-card"
          >
            {project.data.image ? (
              <img 
                src={project.data.image} 
                alt={project.data.title}
                class="w-full h-64 object-cover"
              />
            ) : (
              <div class="w-full h-64 bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                <span class="text-[#4B5563] dark:text-gray-200 text-sm">No image</span>
              </div>
            )}
            <div class="p-4">
              <h2 class="text-xl font-bold mb-3 text-[#1A1A1A] dark:text-gray-100 group-hover:text-[#654321] dark:group-hover:text-[#A67C52] transition-colors">
                {project.data.title}
              </h2>
              
              {publishedDate && (
                <div class="flex items-center gap-4 mb-3 text-sm text-[#4B5563] dark:text-gray-200">
                  <span>Published on: {publishedDate}</span>
                </div>
              )}
              
              {project.data.description && (
                <p class="text-[#4B5563] dark:text-gray-100 mb-4 leading-relaxed">
                  {project.data.description}
                </p>
              )}
              
              {project.data.tags && project.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4 project-tags">
                  {project.data.tags.map((tag) => (
                    <span class="px-3 py-1 bg-[#A67C52] dark:bg-[#D97706] text-white text-xs rounded-full group-hover:bg-[#654321] dark:group-hover:bg-[#A67C52] transition-colors duration-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
              
              <span class="text-[#654321] dark:text-[#A67C52] font-medium inline-flex items-center gap-1 transition-all duration-300 ease-in-out">
                Read more
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
    <div class="text-center mt-8 sm:mt-10">
      <a 
        href="/projects" 
        class="inline-flex items-center justify-center gap-2 border border-[#E5E7EB] dark:border-gray-600 bg-white dark:bg-gray-800 px-6 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-300 ease-in-out transform hover:scale-105 text-[#1A1A1A] dark:text-gray-200 font-medium shadow-sm hover:shadow-md"
      >
        View All Projects
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Resume Section -->
  <section id="resume" class="w-full px-4 sm:px-6 py-8 sm:py-12">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-6 sm:mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-[#1A1A1A] dark:text-gray-100">Resume</h2>
        <a 
          href="/resume.pdf" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#654321] dark:bg-[#A67C52] text-white px-5 py-2.5 rounded-xl hover:opacity-90 transition-all duration-300 ease-in-out transform hover:scale-105 text-sm"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download Resume
        </a>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-[#F3F4F6] dark:border-gray-700 shadow-sm overflow-hidden">
        <div class="overflow-auto max-h-[80vh] sm:max-h-none">
          <iframe 
            src="/resume.pdf#toolbar=0&navpanes=0&scrollbar=1" 
            class="w-full h-[1200px] sm:h-[700px] md:h-[800px] border-0"
            title="Resume PDF"
            style="border: none; min-height: 1200px;"
          >
          <p class="p-6 text-[#4B5563] dark:text-gray-100">
            Your browser does not support PDFs. 
            <a href="/resume.pdf" target="_blank" class="text-[#654321] dark:text-[#A67C52] hover:underline">Download the PDF</a> instead.
          </p>
        </iframe>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Hero Section Animations */
    .hero-content {
      animation: fadeInUp 0.8s ease-out;
    }

    .hero-title {
      animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    .hero-subtitle {
      animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .hero-bio {
      animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    .hero-image {
      animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Hero Section Animations */
    .hero-content {
      animation: fadeInUp 0.8s ease-out;
    }

    .hero-title {
      animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    .hero-subtitle {
      animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .hero-bio {
      animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    .hero-image {
      animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Enhanced Project Card Hover Effects */
    .project-card {
      position: relative;
    }

    .project-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: 0.75rem;
      padding: 2px;
      background: linear-gradient(135deg, #654321, #A67C52);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .project-card:hover::before {
      opacity: 1;
    }

    .project-card:hover {
      z-index: 1;
    }
  </style>

</Base>
