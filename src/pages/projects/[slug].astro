---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import ProjectImage from "../../components/ProjectImage.astro";
import ProjectImages from "../../components/ProjectImages.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const publishedDate = project.data.publishedDate 
  ? new Date(project.data.publishedDate).toLocaleDateString('en-US', { 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric' 
    })
  : null;
---

<Base title={`${project.data.title} - Parth Dhingra`}>
  <style is:global>
    /* Force ALL text in article to be visible in dark mode - most comprehensive */
    html.dark article,
    html.dark article p,
    html.dark article span,
    html.dark article div,
    html.dark article li,
    html.dark article td,
    html.dark article th,
    html.dark article em,
    html.dark article i,
    html.dark article strong,
    html.dark article b,
    html.dark article small,
    html.dark article mark,
    html.dark article del,
    html.dark article ins,
    html.dark article sub,
    html.dark article sup,
    html.dark article *:not(button):not(.bg-\[#D97706\]):not(.bg-\[#A67C52\]):not(.bg-\[#1A1A1A\]):not(.bg-\[#FF0000\]):not(.bg-\[#654321\]):not(svg):not(path):not(img) {
      color: #F3F4F6 !important;
    }
    
    html.dark article h1,
    html.dark article h2,
    html.dark article h3,
    html.dark article h4,
    html.dark article h5,
    html.dark article h6 {
      color: #F9FAFB !important;
    }
    
    html.dark article a:not(.bg-\[#1A1A1A\]):not(.bg-\[#FF0000\]) {
      color: #A67C52 !important;
    }
    
    /* Ensure buttons keep their white text */
    html.dark article button,
    html.dark article .bg-\[#D97706\],
    html.dark article .bg-\[#A67C52\],
    html.dark article .bg-\[#1A1A1A\],
    html.dark article .bg-\[#FF0000\],
    html.dark article .bg-\[#654321\] {
      color: white !important;
    }
  </style>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12 text-[#1A1A1A] dark:text-gray-100">
    <!-- Back Link -->
    <a 
      href="/projects" 
      class="inline-flex items-center gap-2 text-[#4B5563] dark:text-gray-200 hover:text-[#1A1A1A] dark:hover:text-gray-100 transition-colors mb-8 text-sm sm:text-base"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"/>
        <polyline points="12 19 5 12 12 5"/>
      </svg>
      Back to project list
    </a>

    <!-- Project Title -->
    <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-[#1A1A1A] dark:text-gray-100">
      {project.data.title}
    </h1>

    <!-- Metadata -->
    {publishedDate && (
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-8 text-sm sm:text-base text-[#4B5563] dark:text-gray-200">
        <span>Published on: {publishedDate}</span>
      </div>
    )}

    <!-- Project Cover Image -->
    {(project.data.coverImage || project.data.image) && (
      <div class="mb-8 flex justify-center">
        <img 
          src={project.data.coverImage || project.data.image} 
          alt={project.data.title}
          class="rounded-xl object-cover cursor-pointer hover:opacity-90 transition-opacity image-lightbox"
          data-lightbox-src={project.data.coverImage || project.data.image}
          data-lightbox-alt={project.data.title}
          style={`width: ${(project.data.coverImageScale || 100) / 100 * 100}%; max-width: 100%; height: auto;`}
        />
      </div>
    )}

    <!-- Tags -->
    {project.data.tags && project.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {project.data.tags.map((tag) => (
          <span class="px-4 py-1.5 bg-[#D97706] dark:bg-[#A67C52] text-white text-sm rounded-full font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- GitHub and Demo Video Buttons -->
    {((project.data.github && project.data.github.trim() !== '') || (project.data.demoVideo && project.data.demoVideo.trim() !== '')) && (
      <div class="flex flex-wrap gap-3 mb-10">
        {project.data.github && project.data.github.trim() !== '' && (
          <a 
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#1A1A1A] dark:bg-gray-700 text-white px-4 py-2 rounded-xl hover:opacity-90 transition-all duration-300 ease-in-out transform hover:scale-105 text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        )}
        {project.data.demoVideo && project.data.demoVideo.trim() !== '' && (
          <a 
            href={project.data.demoVideo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[#FF0000] text-white px-4 py-2 rounded-xl hover:opacity-90 transition-all duration-300 ease-in-out transform hover:scale-105 text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            View Demo Video
          </a>
        )}
      </div>
    )}

    <!-- Overview Section -->
    {project.data.sectionTitle && project.data.sectionContent && (
      <div class="project-content overview-section">
        <h2 class="overview-title" style="font-size: 2.5rem; font-weight: 900; margin-top: 2.5rem; margin-bottom: 2rem; line-height: 1.2; letter-spacing: -0.025em; font-family: 'Inter', system-ui, sans-serif;">
          {project.data.sectionTitle}
        </h2>
        <p class="overview-content" style="font-size: 1.125rem; margin-bottom: 2.5rem; line-height: 1.75;">
          {project.data.sectionContent}
        </p>
      </div>
    )}

    <!-- Project Content (Markdown) -->
    <div class="project-content max-w-none">
      <Content components={{ ProjectImage, ProjectImages }} />
    </div>

    <!-- Additional Images -->
    {project.data.image2 && (
      <div class="mb-8 mt-10">
        <img 
          src={project.data.image2} 
          alt={project.data.title}
          class="w-full rounded-xl object-cover"
        />
      </div>
    )}
    {project.data.image3 && (
      <div class="mb-8">
        <img 
          src={project.data.image3} 
          alt={project.data.title}
          class="w-full rounded-xl object-cover"
        />
      </div>
    )}
    {project.data.image4 && (
      <div class="mb-8">
        <img 
          src={project.data.image4} 
          alt={project.data.title}
          class="w-full rounded-xl object-cover"
        />
      </div>
    )}
  </article>

  <style>
    /* Project content styling */
    .project-content {
      color: #1A1A1A;
      line-height: 1.75;
      font-size: 1.125rem;
    }

    /* Force dark mode text to be visible - highest priority */
    html.dark .project-content,
    html.dark .project-content *:not(button):not(.bg-\[#D97706\]):not(.bg-\[#A67C52\]):not(.bg-\[#1A1A1A\]):not(.bg-\[#FF0000\]):not(svg):not(path) {
      color: #F3F4F6 !important;
    }
    
    html.dark article,
    html.dark article *:not(button):not(.bg-\[#D97706\]):not(.bg-\[#A67C52\]):not(.bg-\[#1A1A1A\]):not(.bg-\[#FF0000\]):not(svg):not(path):not(img) {
      color: #F3F4F6 !important;
    }
    
    /* Catch any text nodes that might be direct children */
    html.dark article > *,
    html.dark .project-content > * {
      color: #F3F4F6 !important;
    }

    /* Ensure all text elements in dark mode inherit light color */
    html.dark .project-content :global(span),
    html.dark .project-content :global(div),
    html.dark .project-content :global(em),
    html.dark .project-content :global(i),
    html.dark .project-content :global(table),
    html.dark .project-content :global(td),
    html.dark .project-content :global(th),
    html.dark .project-content :global(section),
    html.dark .project-content :global(article),
    html.dark .project-content :global(main),
    html.dark .project-content :global(header),
    html.dark .project-content :global(footer),
    html.dark .project-content :global(nav),
    html.dark .project-content :global(aside),
    html.dark article span,
    html.dark article div:not([class*="bg-"]):not(button),
    html.dark article section,
    html.dark article article {
      color: #F3F4F6 !important;
    }

    /* Use :global() to target rendered markdown content */
    .project-content :global(h1),
    .project-content :global(h2),
    .project-content :global(h3),
    .project-content :global(h4),
    .project-content :global(h5),
    .project-content :global(h6) {
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(h1),
    html.dark .project-content :global(h2),
    html.dark .project-content :global(h3),
    html.dark .project-content :global(h4),
    html.dark .project-content :global(h5),
    html.dark .project-content :global(h6),
    html.dark article h1,
    html.dark article h2,
    html.dark article h3,
    html.dark article h4,
    html.dark article h5,
    html.dark article h6 {
      color: #F9FAFB !important;
    }

    .project-content :global(h2) {
      font-size: 2rem !important;
      font-weight: 900 !important;
      margin-top: 4rem !important;
      margin-bottom: 2rem !important;
      line-height: 1.2 !important;
      letter-spacing: -0.025em !important;
      font-family: 'Inter', system-ui, sans-serif !important;
    }

    /* First h2 in markdown content */
    .project-content :global(h2:first-of-type) {
      margin-top: 2.5rem !important;
    }

    /* Target ALL h3 headings */
    .project-content :global(h3) {
      font-size: 1.75rem !important;
      font-weight: 800 !important;
      margin-top: 3rem !important;
      margin-bottom: 1rem !important;
      line-height: 1.3 !important;
      letter-spacing: -0.01em !important;
    }

    .project-content :global(p) {
      font-size: 1.125rem !important;
      margin-bottom: 2.5rem !important;
      line-height: 1.75 !important;
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(p) {
      color: #F3F4F6 !important;
    }

    .project-content :global(strong) {
      font-weight: 700 !important;
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(strong) {
      color: #F9FAFB !important;
    }

    .project-content :global(ul),
    .project-content :global(ol) {
      margin-bottom: 3rem !important;
      margin-top: 1.5rem !important;
      padding-left: 1.75rem !important;
      color: #1A1A1A !important;
    }
    
    html.dark .project-content :global(ul),
    html.dark .project-content :global(ol),
    html.dark article ul,
    html.dark article ol {
      color: #F3F4F6 !important;
    }

    .project-content :global(li) {
      margin-bottom: 0.875rem !important;
      line-height: 1.75 !important;
      font-size: 1.125rem !important;
      list-style-type: disc !important;
      display: list-item !important;
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(li),
    html.dark article li,
    html.dark article li *,
    html.dark .project-content :global(li *) {
      color: #F3F4F6 !important;
    }

    .project-content :global(a) {
      color: #654321 !important;
      text-decoration: underline !important;
      transition: opacity 0.2s !important;
    }

    html.dark .project-content :global(a) {
      color: #A67C52 !important;
    }

    .project-content :global(a:hover) {
      opacity: 0.8 !important;
    }

    .project-content :global(code) {
      background: #F3F4F6 !important;
      padding: 0.2em 0.4em !important;
      border-radius: 4px !important;
      font-size: 0.9em !important;
      font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', monospace !important;
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(code),
    html.dark article code {
      background: #374151 !important;
      color: #F3F4F6 !important;
    }

    .project-content :global(pre) {
      background: #F3F4F6 !important;
      padding: 1.25rem !important;
      border-radius: 8px !important;
      overflow-x: auto !important;
      margin-bottom: 1.5rem !important;
    }

    html.dark .project-content :global(pre),
    html.dark article pre {
      background: #374151 !important;
    }

    .project-content :global(pre code) {
      background: none !important;
      padding: 0 !important;
      color: #1A1A1A !important;
    }

    html.dark .project-content :global(pre code) {
      color: #F3F4F6 !important;
    }

    .project-content :global(blockquote) {
      border-left: 3px solid #D97706 !important;
      padding-left: 1.25rem !important;
      margin-left: 0 !important;
      margin-bottom: 1.5rem !important;
      color: #4B5563 !important;
      font-style: italic !important;
    }

    html.dark .project-content :global(blockquote),
    html.dark article blockquote {
      color: #F3F4F6 !important;
    }

    .project-content :global(img) {
      border-radius: 8px !important;
      margin-bottom: 1.5rem !important;
    }

    /* Overview Section specific styles */
    .overview-section .overview-title {
      color: #1A1A1A !important;
    }

    html.dark .overview-section .overview-title {
      color: #F9FAFB !important;
    }

    .overview-section .overview-content {
      color: #1A1A1A !important;
    }

    html.dark .overview-section .overview-content {
      color: #F3F4F6 !important;
    }

    /* Links should be visible but different color */
    html.dark article a,
    html.dark article :global(a),
    html.dark .project-content :global(a) {
      color: #A67C52 !important;
    }

    /* FINAL CATCH-ALL: Force any remaining text to be visible */
    html.dark article [class*="project-content"] *,
    html.dark article [class*="project-content"] *::before,
    html.dark article [class*="project-content"] *::after,
    html.dark article > div > *,
    html.dark article > div > * > * {
      color: #F3F4F6 !important;
    }
    
    /* But preserve headings */
    html.dark article [class*="project-content"] h1,
    html.dark article [class*="project-content"] h2,
    html.dark article [class*="project-content"] h3,
    html.dark article [class*="project-content"] h4,
    html.dark article [class*="project-content"] h5,
    html.dark article [class*="project-content"] h6 {
      color: #F9FAFB !important;
    }
  </style>

</Base>
