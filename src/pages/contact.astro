---
import Base from "../layouts/Base.astro";
---

<Base title="Contact - Parth Dhingra">
  <section class="w-full px-6 py-20 max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-[#1A1A1A] dark:text-gray-100">
        Get In Touch
      </h1>
      <p class="text-lg leading-relaxed text-[#4B5563] dark:text-gray-100 max-w-2xl mx-auto">
        Feel free to reach out!
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 mb-8 sm:mb-12">
      <!-- Phone -->
      <a 
        href="tel:+15714649571" 
        class="bg-white dark:bg-gray-800 rounded-xl border border-[#F3F4F6] dark:border-gray-700 p-6 shadow-sm hover:shadow-md transition-all duration-300 ease-in-out transform hover:scale-105 text-center group"
      >
        <div class="w-12 h-12 bg-[#654321] dark:bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#7a5326] transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2 text-[#1A1A1A] dark:text-gray-100">Phone</h3>
        <p class="text-[#4B5563] dark:text-gray-100">+1 (571) 464-9571</p>
      </a>

      <!-- Email -->
      <a 
        href="mailto:parthdhingra27@gmail.com" 
        class="bg-white dark:bg-gray-800 rounded-xl border border-[#F3F4F6] dark:border-gray-700 p-6 shadow-sm hover:shadow-md transition-all duration-300 ease-in-out transform hover:scale-105 text-center group"
      >
        <div class="w-12 h-12 bg-[#654321] dark:bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#7a5326] transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2 text-[#1A1A1A] dark:text-gray-100">Email</h3>
        <p class="text-[#4B5563] dark:text-gray-100">parthdhingra27@gmail.com</p>
      </a>

      <!-- LinkedIn -->
      <a 
        href="https://www.linkedin.com/in/parthd27/" 
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white dark:bg-gray-800 rounded-xl border border-[#F3F4F6] dark:border-gray-700 p-6 shadow-sm hover:shadow-md transition-all duration-300 ease-in-out transform hover:scale-105 text-center group"
      >
        <div class="w-12 h-12 bg-[#654321] dark:bg-[#D97706] rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-[#7a5326] transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2 text-[#1A1A1A] dark:text-gray-100">LinkedIn</h3>
        <p class="text-[#4B5563] dark:text-gray-100">Connect with me</p>
      </a>
    </div>

  </section>
</Base>
